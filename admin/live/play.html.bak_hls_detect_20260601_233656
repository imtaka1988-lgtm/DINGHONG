<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
  <title>顶红体育直播</title>

  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    html, body {
      width:100%;
      min-height:100%;
      background:#070707;
      color:#fff;
      font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",Arial,sans-serif;
    }

    .page {
      max-width:580px;
      margin:0 auto;
      min-height:100vh;
      background:linear-gradient(180deg,#171717 0%,#050505 42%,#101010 100%);
      padding-bottom:78px;
    }

    .top-space {
      padding:12px 12px 0;
    }

    .ad-card {
      width:100%;
      border-radius:16px;
      overflow:hidden;
      background:linear-gradient(135deg,#2b2111,#0f0f0f 58%,#211306);
      border:1px solid rgba(245,197,24,.32);
      box-shadow:0 8px 28px rgba(0,0,0,.45);
      margin-bottom:12px;
      position:relative;
    }

    .ad-card img {
      width:100%;
      display:block;
      height:auto;
    }

    .ad-placeholder {
      min-height:92px;
      display:flex;
      align-items:center;
      justify-content:center;
      flex-direction:column;
      text-align:center;
      padding:18px 12px;
      color:#f5c518;
      letter-spacing:1px;
    }

    .ad-placeholder .main {
      font-size:20px;
      font-weight:800;
      text-shadow:0 0 12px rgba(245,197,24,.35);
    }

    .ad-placeholder .sub {
      margin-top:7px;
      font-size:12px;
      color:#d9c27a;
      opacity:.88;
    }

    .brand-bar {
      margin:0 12px 12px;
      padding:12px 14px;
      border-radius:14px;
      background:rgba(255,255,255,.055);
      border:1px solid rgba(255,255,255,.08);
      display:flex;
      justify-content:space-between;
      align-items:center;
    }

    .brand-title {
      font-size:16px;
      font-weight:800;
      color:#f5f1e8;
    }

    .brand-tag {
      font-size:12px;
      color:#f5c518;
      border:1px solid rgba(245,197,24,.42);
      border-radius:999px;
      padding:4px 9px;
      background:rgba(245,197,24,.08);
    }

    .match-title {
      margin:0 12px;
      padding:11px 12px;
      text-align:center;
      background:#0b0b0b;
      border-radius:14px 14px 0 0;
      border:1px solid rgba(255,255,255,.08);
      border-bottom:0;
      color:#f5f1e8;
      font-weight:700;
      letter-spacing:.5px;
      min-height:42px;
    }

    .video-wrap {
      margin:0 12px;
      background:#000;
      border-radius:0 0 14px 14px;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.08);
      box-shadow:0 10px 30px rgba(0,0,0,.6);
    }

    video {
      width:100%;
      height:auto;
      display:block;
      background:#000;
    }

    .hidden { display:none !important; }

    .tip {
      width:100%;
      min-height:260px;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      background:radial-gradient(ellipse at center,#222 0%,#000 75%);
      text-align:center;
      padding:30px 20px;
    }

    .tip-main {
      font-size:clamp(26px,6vw,44px);
      font-weight:800;
      letter-spacing:4px;
      color:#f5f1e8;
      text-shadow:0 2px 12px rgba(0,0,0,.6);
      display:flex;
      align-items:baseline;
    }

    .tip-main .dots span {
      display:inline-block;
      animation:blink 1.4s infinite both;
    }

    .tip-main .dots span:nth-child(2){ animation-delay:.2s; }
    .tip-main .dots span:nth-child(3){ animation-delay:.4s; }

    @keyframes blink {
      0%,80%,100%{opacity:.2;transform:translateY(0);}
      40%{opacity:1;transform:translateY(-6px);}
    }

    .tip-sub {
      margin-top:16px;
      font-size:14px;
      letter-spacing:1px;
      color:#9a9a9a;
      line-height:1.7;
    }

    .gold-copy {
      margin:12px;
      padding:14px 12px;
      border-radius:14px;
      text-align:center;
      color:#f5c518;
      font-size:15px;
      font-weight:900;
      letter-spacing:1px;
      background:linear-gradient(135deg,rgba(245,197,24,.16),rgba(255,255,255,.04),rgba(245,197,24,.10));
      border:1px solid rgba(245,197,24,.35);
      text-shadow:0 0 8px rgba(245,197,24,.55);
      box-shadow:0 8px 24px rgba(0,0,0,.35);
    }

    .section-title {
      margin:16px 12px 8px;
      font-size:13px;
      color:#aaa;
      display:flex;
      align-items:center;
      gap:8px;
    }

    .section-title:before {
      content:"";
      width:4px;
      height:14px;
      border-radius:9px;
      background:#f5c518;
      display:block;
    }

    .ad-grid {
      padding:0 12px;
      display:grid;
      grid-template-columns:1fr;
      gap:12px;
    }

    .info-panel {
      margin:12px;
      padding:14px;
      border-radius:16px;
      background:rgba(255,255,255,.055);
      border:1px solid rgba(255,255,255,.08);
      color:#ddd;
      line-height:1.8;
      font-size:13px;
    }

    .info-panel b {
      color:#f5c518;
    }

    .bottom-fixed {
      position:fixed;
      left:50%;
      bottom:0;
      transform:translateX(-50%);
      width:100%;
      max-width:580px;
      background:rgba(5,5,5,.94);
      backdrop-filter:blur(12px);
      border-top:1px solid rgba(245,197,24,.28);
      padding:9px 12px;
      display:flex;
      gap:10px;
      z-index:50;
    }

    .bottom-fixed button {
      flex:1;
      border:0;
      border-radius:999px;
      padding:11px 8px;
      font-weight:800;
      font-size:14px;
    }

    .btn-gold {
      background:linear-gradient(135deg,#f5c518,#b8860b);
      color:#111;
    }

    .btn-dark {
      background:#222;
      color:#eee;
      border:1px solid rgba(255,255,255,.12) !important;
    }

    .banner-dynamic {
      padding:0 12px;
      margin-top:12px;
    }

    .banner-dynamic img {
      width:100%;
      border-radius:16px;
      display:block;
      border:1px solid rgba(255,255,255,.08);
    }

    .modal-mask {
      position:fixed;
      inset:0;
      z-index:999998;
      background:rgba(0,0,0,.72);
      display:none;
      align-items:center;
      justify-content:center;
      padding:18px;
    }

    .modal-card {
      width:100%;
      max-width:420px;
      border-radius:22px;
      background:linear-gradient(180deg,#1a1a1a,#080808);
      border:1px solid rgba(245,197,24,.42);
      box-shadow:0 18px 60px rgba(0,0,0,.68);
      overflow:hidden;
      color:#fff;
    }

    .modal-head {
      padding:18px 16px;
      text-align:center;
      background:linear-gradient(135deg,rgba(245,197,24,.28),rgba(255,255,255,.04));
      border-bottom:1px solid rgba(245,197,24,.28);
    }

    .modal-head .title {
      font-size:22px;
      font-weight:900;
      color:#f5c518;
      letter-spacing:1px;
    }

    .modal-head .sub {
      margin-top:6px;
      font-size:13px;
      color:#d8d8d8;
    }

    .modal-body {
      padding:16px;
    }

    .contact-row {
      margin-bottom:12px;
      padding:12px;
      border-radius:14px;
      background:rgba(255,255,255,.055);
      border:1px solid rgba(255,255,255,.08);
    }

    .contact-label {
      font-size:12px;
      color:#aaa;
      margin-bottom:6px;
    }

    .contact-value {
      color:#f5f1e8;
      font-size:15px;
      font-weight:800;
      word-break:break-all;
    }

    .modal-actions {
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      margin-top:14px;
    }

    .modal-actions button,
    .modal-actions a {
      text-decoration:none;
      text-align:center;
      border:0;
      border-radius:999px;
      padding:12px 10px;
      font-weight:900;
      font-size:14px;
    }

    .modal-copy {
      background:#222;
      color:#eee;
      border:1px solid rgba(255,255,255,.12) !important;
    }

    .modal-primary {
      background:linear-gradient(135deg,#f5c518,#b8860b);
      color:#111;
    }

    .modal-close {
      width:100%;
      margin-top:12px;
      border:0;
      border-radius:999px;
      padding:11px;
      background:rgba(255,255,255,.08);
      color:#ddd;
      font-weight:800;
    }


  </style>
</head>

<body>
<div class="page">

  <div class="top-space">
    <div class="ad-card">
      <img id="topAdImg" src="img/top.png" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
      <div class="ad-placeholder" style="display:none;">
        <div class="main">顶部广告位</div>
        <div class="sub">建议尺寸：750 × 220，可放品牌图 / 活动图 / 扫码引导</div>
      </div>
    </div>
  </div>

  <div class="brand-bar">
    <div class="brand-title">顶红体育直播</div>
    <div class="brand-tag">赛事直播入口</div>
  </div>

  <div id="matchTitle" class="match-title">正在获取赛事信息</div>

  <div class="video-wrap">
    <video id="video" class="hidden" controls autoplay playsinline muted></video>

    <div id="tip" class="tip">
      <div class="tip-main">顶红体育直播<span class="dots"><span>.</span><span>.</span><span>.</span></span></div>
      <div id="tipSub" class="tip-sub">正在获取直播信号，请稍候</div>
    </div>
  </div>

  <div class="gold-copy">
    赛事福利与固定联系，请点击右下角联系专员
  </div>

  <div id="bottomBanner" class="banner-dynamic"></div>

  <div class="section-title">观赛提示</div>

  <div class="info-panel">
    <b>提示：</b>如遇短暂黑屏或加载较慢，请先点击下方“刷新直播”。<br>
    <b>说明：</b>本页面会根据二维码自动识别比赛，直播链接固定，线路自动读取。<br>
    <b>联系：</b>多次刷新仍无法播放时，请点击“联系专员”说明比赛名称。
  </div>

  <div class="ad-grid">
    <div id="ad1Wrap" class="ad-card hidden">
      <img id="ad1Img" src="" alt="推荐广告1">
    </div>
    <div id="ad2Wrap" class="ad-card hidden">
      <img id="ad2Img" src="" alt="推荐广告2">
    </div>
    <div id="bottomAdWrap" class="ad-card hidden">
      <img id="bottomAdImg" src="" alt="底部广告">
    </div>
  </div>

</div>

<div class="bottom-fixed">
  <button id="refreshBtn" class="btn-dark" type="button" onclick="dhRefreshLive()">刷新直播</button>
  <button id="contactBtn" class="btn-gold" type="button" onclick="openHaiouModal()">联系专员</button>
</div>

<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<script src="https://cdn.jsdelivr.net/npm/mpegts.js@latest"></script>

<script>
  var key = (location.search.match(/key=([a-z0-9_\-]+)/i) || [])[1] || '';
  var API = 'https://api.5q.lol/live/status?key=';

  var video = document.getElementById('video');
  var tip = document.getElementById('tip');
  var tipSub = document.getElementById('tipSub');
  var matchTitle = document.getElementById('matchTitle');

  var player = null;
  var hls = null;
  var currentUrl = '';
  var playing = false;

  function setTip(msg) {
    tip.classList.remove('hidden');
    video.classList.add('hidden');
    tipSub.innerText = msg || '正在获取直播信号，请稍候';
  }

  function friendlyLiveMessage(message, status) {
    var m = (message || '').toString();
    var s = (status || '').toString().toUpperCase();

    if (s === 'WAITING') return '比赛尚未开始，开赛前请回来刷新';
    if (s === 'FINISHED' || s === 'ENDED' || s === 'CLOSED' || s === 'OFFLINE') return '本场直播已结束，感谢观看';
    if (s === 'NO_RIGHTS') return '当前暂无本场直播信号';
    if (s === 'NOT_FOUND' || s === 'INVALID') return '直播链接无效，请从公众号菜单重新进入';

    if (m.indexOf('key') >= 0 || m.indexOf('参数') >= 0) return '直播链接无效，请从公众号菜单重新进入';
    if (m.indexOf('源') >= 0 || m.indexOf('信号') >= 0) return '直播信号正在接入，请稍后刷新';
    if (m.indexOf('获取失败') >= 0 || m.indexOf('异常') >= 0) return '直播状态暂时无法获取，请稍后刷新';

    return m || '本场直播暂不可用，请稍后刷新';
  }

  function destroyPlayers() {
    if (player) {
      try { player.unload(); player.detachMediaElement(); player.destroy(); } catch(e) {}
      player = null;
    }
    if (hls) {
      try { hls.destroy(); } catch(e) {}
      hls = null;
    }
    try {
      video.pause();
      video.removeAttribute('src');
      video.load();
    } catch(e) {}
    playing = false;
  }


  function getPlayableUrl(streamUrl, streamType) {
    var type = (streamType || '').toLowerCase();

    if (!type || type === 'auto') {
      if (streamUrl.indexOf('.m3u8') > -1) type = 'hls';
      else type = 'flv';
    }

    // FLV 统一走后端代理，解决源站防盗链 / CORS / 浏览器 Referer 被拒
    if (type === 'flv') {
      return '/live/proxy?key=' + encodeURIComponent(key) + '&t=' + Date.now();
    }

    return streamUrl;
  }


  function startPlay(streamUrl, streamType) {
    if (!streamUrl) {
      destroyPlayers();
      setTip('直播信号正在接入，请稍后刷新');
      return;
    }

    if (playing && currentUrl === streamUrl) return;

    destroyPlayers();
    currentUrl = streamUrl;

    tip.classList.add('hidden');
    video.classList.remove('hidden');

    var type = (streamType || '').toLowerCase();
    if (!type || type === 'auto') {
      if (streamUrl.indexOf('.m3u8') > -1) type = 'hls';
      else type = 'flv';
    }

    if (type === 'hls') {
      if (video.canPlayType('application/vnd.apple.mpegurl')) {
        video.src = streamUrl;
        video.play().catch(function(){});
        playing = true;
        return;
      }
      if (window.Hls && Hls.isSupported()) {
        hls = new Hls();
        hls.loadSource(streamUrl);
        hls.attachMedia(video);
        hls.on(Hls.Events.MANIFEST_PARSED, function(){
          video.play().catch(function(){});
        });
        playing = true;
        return;
      }
      setTip('当前浏览器暂不支持播放，请刷新页面或联系专员');
      return;
    }

    if (window.mpegts) {
      var feature = mpegts.getFeatureList ? mpegts.getFeatureList() : {};
      if (!feature.mseLivePlayback) {
        setTip('当前浏览器暂不支持该线路，请刷新页面或联系专员');
        return;
      }

      var playUrl = getPlayableUrl(streamUrl, type);

      try {
        player = mpegts.createPlayer({
          type: 'flv',
          isLive: true,
          url: playUrl,
          cors: true,
          enableWorker: false,
          enableStashBuffer: false,
          stashInitialSize: 128
        });

        if (player.on && mpegts.Events) {
          player.on(mpegts.Events.ERROR, function(errorType, errorDetail, errorInfo) {
            console.log('[LIVE_PLAYER_ERROR]', errorType, errorDetail, errorInfo);
            setTip('直播信号临时波动，请点击下方“刷新直播”');
          });

          player.on(mpegts.Events.LOADING_COMPLETE, function() {
            console.log('[LIVE_LOADING_COMPLETE]');
          });

          player.on(mpegts.Events.RECOVERED_EARLY_EOF, function() {
            console.log('[LIVE_RECOVERED_EOF]');
          });
        }

        video.onerror = function() {
          var err = video.error;
          var code = err ? err.code : 'unknown';
          console.log('[VIDEO_ERROR]', err);
          setTip('直播画面加载异常，请点击下方“刷新直播”');
        };

        video.oncanplay = function() {
          console.log('[VIDEO_CAN_PLAY]');
        };

        video.onplaying = function() {
          console.log('[VIDEO_PLAYING]');
        };

        player.attachMediaElement(video);
        player.load();

        video.play().then(function(){
          console.log('[VIDEO_PLAY_OK]', playUrl);
        }).catch(function(e){
          console.log('[VIDEO_PLAY_BLOCKED]', e);
          setTip('请点击播放器播放按钮开始观看');
          video.classList.remove('hidden');
          tip.classList.add('hidden');
        });

        playing = true;
        return;

      } catch(e) {
        console.log('[PLAYER_INIT_ERROR]', e);
        setTip('播放器加载失败，请点击下方“刷新直播”');
        return;
      }
    }

    setTip('播放器组件加载失败，请刷新页面重试');
  }









  function dhToast(text) {
    var old = document.getElementById("dhToast");
    if (old) old.remove();

    var tip = document.createElement("div");
    tip.id = "dhToast";
    tip.innerText = text || "处理中...";
    tip.style.cssText =
      "position:fixed;left:50%;bottom:74px;transform:translateX(-50%);" +
      "z-index:999999;background:rgba(0,0,0,.88);color:#f5c518;" +
      "border:1px solid rgba(245,197,24,.45);border-radius:999px;" +
      "padding:9px 14px;font-size:13px;font-weight:800;" +
      "box-shadow:0 8px 24px rgba(0,0,0,.45);";
    document.body.appendChild(tip);

    setTimeout(function(){
      var t = document.getElementById("dhToast");
      if (t) t.remove();
    }, 1800);
  }

  function dhRefreshLive() {
    var btn = document.getElementById("refreshBtn");
    var oldText = btn ? btn.innerText : "刷新直播";

    if (btn) {
      btn.innerText = "刷新中...";
      btn.disabled = true;
    }

    try {
      destroyPlayers();
      currentUrl = "";
      playing = false;
      setTip("正在重新获取直播信号...");
      checkStatus();
      dhToast("正在刷新直播");
    } catch(e) {
      dhToast("刷新失败，请稍后重试");
    }

    setTimeout(function(){
      if (btn) {
        btn.innerText = oldText || "刷新直播";
        btn.disabled = false;
      }
    }, 1200);
  }

  function openHaiouModal() {
    var m = document.getElementById("haiouModal");
    if (m) m.style.display = "flex";
  }

  function closeHaiouModal() {
    var m = document.getElementById("haiouModal");
    if (m) m.style.display = "none";
  }

  function copyText(text, msg) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(function(){
        dhToast(msg || "已复制");
      }).catch(function(){
        fallbackCopyText(text, msg);
      });
    } else {
      fallbackCopyText(text, msg);
    }
  }

  function fallbackCopyText(text, msg) {
    var input = document.createElement("input");
    input.value = text;
    document.body.appendChild(input);
    input.select();

    try {
      document.execCommand("copy");
      dhToast(msg || "已复制");
    } catch(e) {
      prompt("请手动复制", text);
    }

    input.remove();
  }



  function checkStatus() {
    if (!key) {
      matchTitle.innerText = '直播链接无效';
      setTip('直播链接无效，请从公众号菜单重新进入');
      return;
    }

    if (!playing) setTip('正在获取直播信号，请稍候');

    fetch(API + encodeURIComponent(key) + '&t=' + Date.now())
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (d.title) {
          matchTitle.innerText = d.title;
        }

        if (d.online && d.streamUrl) {
          startPlay(d.streamUrl, d.streamType || 'auto');
        } else {
          destroyPlayers();
          setTip(friendlyLiveMessage(d.message, d.status));
        }
      })
      .catch(function(){
        destroyPlayers();
        setTip('直播状态暂时无法获取，请稍后刷新');
      });
  }

  var currentBanner = '';

  function checkBanner(){
    fetch('banner.txt?t=' + Date.now())
      .then(function(r){ return r.text(); })
      .then(function(u){
        u = u.trim();
        if (u !== currentBanner){
          currentBanner = u;
          var box = document.getElementById('bottomBanner');
          if (u){
            box.innerHTML = '<div class="section-title">动态推荐</div><img src="' + u + '?v=' + Date.now() + '">';
          } else {
            box.innerHTML = '';
          }
        }
      })
      .catch(function(){});
  }

  function scrollToAd(){
    var el = document.querySelector('.gold-copy');
    if(el) el.scrollIntoView({behavior:'smooth', block:'center'});
  }


  function setAdImage(id, url){
    var img = document.getElementById(id);
    if(!img) return;

    var wrap = img.closest ? img.closest('.ad-card') : null;
    var isTop = id === 'topAdImg';

    if(!url){
      if(!isTop && wrap) wrap.classList.add('hidden');
      return;
    }

    if(wrap) wrap.classList.remove('hidden');
    img.src = url;
    img.style.display = 'block';

    if(img.nextElementSibling){
      img.nextElementSibling.style.display = 'none';
    }
  }

  function loadAdConfig(){
    fetch('ad_config.json?t=' + Date.now())
      .then(function(r){ return r.json(); })
      .then(function(c){
        setAdImage('topAdImg', c.top);
        setAdImage('ad1Img', c.ad1);
        setAdImage('ad2Img', c.ad2);
        setAdImage('bottomAdImg', c.bottom);
      })
      .catch(function(){});
  }


