<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
  <title>直播</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    html, body { width:100%; min-height:100%; background:#000; }
    .wrap { max-width:580px; margin:0 auto;
            display:flex; flex-direction:column; align-items:center;
            padding-top:40px; }
    .banner { width:100%; height:auto; display:block; }
    .video-box { width:100%; background:#000; }
    video { width:100%; height:auto; display:block; background:#000; }
    .tip { width:100%; min-height:260px; display:flex; flex-direction:column;
           align-items:center; justify-content:center;
           background:radial-gradient(ellipse at center,#1a1a1a 0%,#000 75%);
           text-align:center; padding:30px 20px; }
    .tip-main { font-size:clamp(26px,6vw,44px); font-weight:700; letter-spacing:4px;
                color:#f5f1e8; text-shadow:0 2px 12px rgba(0,0,0,.6);
                display:flex; align-items:baseline; }
    .tip-main .dots span { display:inline-block; animation:blink 1.4s infinite both; }
    .tip-main .dots span:nth-child(2){ animation-delay:.2s; }
    .tip-main .dots span:nth-child(3){ animation-delay:.4s; }
    @keyframes blink { 0%,80%,100%{opacity:.2;transform:translateY(0);}
                       40%{opacity:1;transform:translateY(-6px);} }
    .tip-sub { margin-top:16px; font-size:clamp(13px,3vw,16px); letter-spacing:2px;
               color:#8a8a8a; line-height:1.7; }
    .match-title { width:100%; color:#f5f1e8; font-size:16px; text-align:center;
                   padding:10px 12px; background:#080808; letter-spacing:1px; }
    .hidden { display:none; }
  </style>
</head>
<body>
  <div class="wrap">
    <img class="banner" src="img/top.png" alt="">
    <div class="video-box">
      <div id="matchTitle" class="match-title hidden"></div>
      <video id="video" class="hidden" controls autoplay playsinline muted></video>
      <div id="tip" class="tip">
        <div class="tip-main">HO体育直播<span class="dots"><span>.</span><span>.</span><span>.</span></span></div>
        <div id="tipSub" class="tip-sub">正在加载，请稍候</div>
      </div>
    </div>
    <div style="width:100%;text-align:center;color:#f5c518;font-size:15px;font-weight:bold;padding:12px 10px;letter-spacing:1px;text-shadow:0 0 8px rgba(245,197,24,.9), 0 0 16px rgba(245,197,24,.5);">首单不中全额返，福利注册后扫下方二维码联系专员</div>
    <div id="bottomBanner" style="width:100%;text-align:center;margin:10px 0;"></div>
    <img class="banner" src="img/bottom.png" alt="">
  </div>

  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
  <script src="https://cdn.jsdelivr.net/npm/mpegts.js@latest"></script>

  <script>
    var key = (location.search.match(/key=([a-z0-9_\-]+)/i) || [])[1] || '';
    var API = 'https://api.5q.lol/live/status?key=';

    var video = document.getElementById('video');
    var tip = document.getElementById('tip');
    var tipSub = document.getElementById('tipSub');
    var matchTitle = document.getElementById('matchTitle');

    var player = null;
    var hls = null;
    var currentUrl = '';
    var playing = false;

    function setTip(msg) {
      tip.classList.remove('hidden');
      video.classList.add('hidden');
      tipSub.innerHTML = msg || '正在加载，请稍候';
    }

    function destroyPlayers() {
      if (player) {
        try { player.unload(); player.detachMediaElement(); player.destroy(); } catch(e) {}
        player = null;
      }
      if (hls) {
        try { hls.destroy(); } catch(e) {}
        hls = null;
      }
      try {
        video.pause();
        video.removeAttribute('src');
        video.load();
      } catch(e) {}
      playing = false;
    }

    function startPlay(streamUrl, streamType) {
      if (!streamUrl) {
        destroyPlayers();
        setTip('直播源暂未配置');
        return;
      }

      if (playing && currentUrl === streamUrl) return;

      destroyPlayers();
      currentUrl = streamUrl;

      tip.classList.add('hidden');
      video.classList.remove('hidden');

      var type = (streamType || '').toLowerCase();
      if (!type || type === 'auto') {
        if (streamUrl.indexOf('.m3u8') > -1) type = 'hls';
        else type = 'flv';
      }

      if (type === 'hls') {
        if (video.canPlayType('application/vnd.apple.mpegurl')) {
          video.src = streamUrl;
          video.play().catch(function(){});
          playing = true;
          return;
        }
        if (window.Hls && Hls.isSupported()) {
          hls = new Hls();
          hls.loadSource(streamUrl);
          hls.attachMedia(video);
          hls.on(Hls.Events.MANIFEST_PARSED, function(){
            video.play().catch(function(){});
          });
          playing = true;
          return;
        }
        setTip('当前浏览器暂不支持该直播源');
        return;
      }

      if (window.mpegts && mpegts.getFeatureList().mseLivePlayback) {
        player = mpegts.createPlayer({
          type: 'flv',
          isLive: true,
          url: streamUrl
        });
        player.attachMediaElement(video);
        player.load();
        video.play().catch(function(){});
        playing = true;
        return;
      }

      setTip('当前浏览器暂不支持FLV直播播放');
    }

    function checkStatus() {
      if (!key) {
        setTip('缺少直播参数');
        return;
      }

      fetch(API + encodeURIComponent(key) + '&t=' + Date.now())
        .then(function(r){ return r.json(); })
        .then(function(d){
          if (d.title) {
            matchTitle.innerText = d.title;
            matchTitle.classList.remove('hidden');
          }

          if (d.online && d.streamUrl) {
            startPlay(d.streamUrl, d.streamType || 'auto');
          } else {
            destroyPlayers();
            setTip(d.message || '本场直播暂不可用');
          }
        })
        .catch(function(){
          destroyPlayers();
          setTip('直播状态获取失败，请稍后重试');
        });
    }

    var currentBanner = '';
    function checkBanner(){
      fetch('banner.txt?t=' + Date.now())
        .then(function(r){ return r.text(); })
        .then(function(u){
          u = u.trim();
          if (u !== currentBanner){
            currentBanner = u;
            var box = document.getElementById('bottomBanner');
            if (u){
              box.innerHTML = '<img src="' + u + '?v=' + Date.now() +
                '" style="max-width:100%;height:auto;border-radius:8px;">';
            } else {
              box.innerHTML = '';
            }
          }
        })
        .catch(function(){});
    }

    checkBanner();
    setInterval(checkBanner, 15000);

    checkStatus();
    setInterval(checkStatus, 15000);
  </script>

  <!-- 在线客服 -->
  <script>
    (function(d, w, c) {
      if (w[c]) return;
      var s = d.createElement("script");
      w[c] = function() {
