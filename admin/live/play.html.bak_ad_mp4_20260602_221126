<script src="https://cdn.jsdelivr.net/npm/live2d-widget@3.0.4/lib/L2Dwidget.min.js"></script>
<script>
(function(){
  var words = [
    "欢迎来到顶红体育直播间～",
    "画面加载慢，先点“刷新直播”。",
    "右下角联系专员，享受首单100%包赔。",
    "实名绑卡享受100送100特权卡。",
    "万人内群，每日精准推单。",
    "今晚一起看球，跟随红单，冲！冲！冲！",
    "海鸥海鸥，记得看一眼。",
    "脑子抹了开塞露，奇思妙想挡不住。"
  ];

  /* 当前为之前尺寸的 50% */
  var defaultPos = {
    left: 8,
    bottom: 78,
    width: 61,
    height: 89
  };

  var pos = loadPos();
  var down = false;
  var dragging = false;
  var startX = 0;
  var startY = 0;
  var startLeft = 0;
  var startBottom = 0;
  var bubbleTimer = null;

  function loadPos(){
    try {
      var saved = localStorage.getItem("dh_live2d_pos");
      if (saved) {
        var obj = JSON.parse(saved);
        if (typeof obj.left === "number" && typeof obj.bottom === "number") {
          return {
            left: obj.left,
            bottom: obj.bottom,
            width: defaultPos.width,
            height: defaultPos.height
          };
        }
      }
    } catch(e) {}
    return Object.assign({}, defaultPos);
  }

  function savePos(){
    try {
      localStorage.setItem("dh_live2d_pos", JSON.stringify({
        left: pos.left,
        bottom: pos.bottom
      }));
    } catch(e) {}
  }

  function lockPage(){
    document.documentElement.classList.add("dh-live2d-dragging");
    document.body.classList.add("dh-live2d-dragging");

    var mask = document.getElementById("dhLive2dDragMask");
    if (mask) {
      mask.style.display = "block";
    }
  }

  function unlockPage(){
    document.documentElement.classList.remove("dh-live2d-dragging");
    document.body.classList.remove("dh-live2d-dragging");

    var mask = document.getElementById("dhLive2dDragMask");
    if (mask) {
      mask.style.display = "none";
    }
  }

  function clampPos(){
    var vw = window.innerWidth || document.documentElement.clientWidth;
    var vh = window.innerHeight || document.documentElement.clientHeight;

    pos.left = Math.max(0, Math.min(pos.left, vw - pos.width - 2));
    pos.bottom = Math.max(58, Math.min(pos.bottom, vh - pos.height - 4));
  }

  function getLive2dEls(){
    return [
      document.getElementById("live2d-widget"),
      document.getElementById("live2dcanvas")
    ].filter(Boolean);
  }

  function applyPos(){
    clampPos();

    getLive2dEls().forEach(function(el){
      el.style.position = "fixed";
      el.style.left = pos.left + "px";
      el.style.right = "auto";
      el.style.bottom = pos.bottom + "px";
      el.style.top = "auto";
      el.style.width = pos.width + "px";
      el.style.height = pos.height + "px";
      el.style.zIndex = "42";
      el.style.outline = "none";
      el.style.border = "none";
      el.style.boxShadow = "none";
      el.style.webkitUserSelect = "none";
      el.style.userSelect = "none";
      el.style.webkitTouchCallout = "none";
      el.style.touchAction = "none";
      el.setAttribute("tabindex", "-1");
      if (el.blur) el.blur();
    });

    applyBubblePos();
  }

  function applyBubblePos(){
    var bubble = document.getElementById("dhLive2dBubble");
    if (!bubble) return;

    var vw = window.innerWidth || document.documentElement.clientWidth;
    var vh = window.innerHeight || document.documentElement.clientHeight;

    var bubbleWidth = Math.min(178, vw - 24);
    var bubbleHeight = 72;

    var preferRight = pos.left + pos.width + bubbleWidth + 18 <= vw;

    var bubbleLeft;
    var bubbleBottom = pos.bottom + Math.floor(pos.height * 0.48);

    if (preferRight) {
      bubbleLeft = pos.left + pos.width + 8;
      bubble.classList.remove("dh-arrow-right");
      bubble.classList.add("dh-arrow-left");
    } else {
      bubbleLeft = pos.left - bubbleWidth - 8;
      bubble.classList.remove("dh-arrow-left");
      bubble.classList.add("dh-arrow-right");
    }

    bubbleLeft = Math.max(8, Math.min(bubbleLeft, vw - bubbleWidth - 8));
    bubbleBottom = Math.max(72, Math.min(bubbleBottom, vh - bubbleHeight - 8));

    bubble.style.left = bubbleLeft + "px";
    bubble.style.bottom = bubbleBottom + "px";
  }

  function hitLive2d(e){
    var x = e.clientX;
    var y = e.clientY;
    var left = pos.left;
    var right = pos.left + pos.width;
    var top = window.innerHeight - pos.bottom - pos.height;
    var bottom = window.innerHeight - pos.bottom;

    return x >= left && x <= right && y >= top && y <= bottom;
  }

  function showBubble(text){
    var bubble = document.getElementById("dhLive2dBubble");
    if (!bubble) return;

    applyBubblePos();

    bubble.innerText = text || words[Math.floor(Math.random() * words.length)];
    bubble.style.display = "block";

    clearTimeout(bubbleTimer);
    bubbleTimer = setTimeout(function(){
      bubble.style.display = "none";
    }, 3000);
  }

  function hideBubble(){
    var bubble = document.getElementById("dhLive2dBubble");
    if (bubble) bubble.style.display = "none";
  }

  function initLive2d(){
    if (!window.L2Dwidget) return;

    L2Dwidget.init({
      model: {
        jsonPath: "https://unpkg.com/live2d-widget-model-miku@1.0.5/assets/miku.model.json"
      },
      display: {
        position: "left",
        width: defaultPos.width,
        height: defaultPos.height,
        hOffset: defaultPos.left,
        vOffset: defaultPos.bottom
      },
      mobile: {
        show: true,
        scale: 0.68
      },
      react: {
        opacityDefault: 0.90,
        opacityOnHover: 1
      },
      dialog: {
        enable: false,
        hitokoto: false
      },
      log: false
    });

    var tries = 0;
    var timer = setInterval(function(){
      tries++;
      applyPos();

      if (document.getElementById("live2dcanvas") || tries >= 30) {
        clearInterval(timer);
        setTimeout(function(){
          applyPos();
          showBubble("欢迎来到顶红体育直播间，点我可以查看提示～");
        }, 600);
      }
    }, 300);
  }

  function stopNative(e){
    if (!down) return;
    if (e.cancelable) e.preventDefault();
    e.stopPropagation();
    return false;
  }

  document.addEventListener("selectstart", stopNative, true);
  document.addEventListener("dragstart", stopNative, true);

  document.addEventListener("contextmenu", function(e){
    if (down || dragging) {
      if (e.cancelable) e.preventDefault();
      e.stopPropagation();
      return false;
    }
  }, true);

  document.addEventListener("touchmove", function(e){
    if (down || dragging) {
      if (e.cancelable) e.preventDefault();
      e.stopPropagation();
      return false;
    }
  }, { passive: false, capture: true });

  document.addEventListener("pointerdown", function(e){
    if (!hitLive2d(e)) return;

    if (e.cancelable) e.preventDefault();
    e.stopPropagation();

    down = true;
    dragging = false;
    startX = e.clientX;
    startY = e.clientY;
    startLeft = pos.left;
    startBottom = pos.bottom;

    lockPage();
  }, true);

  document.addEventListener("pointermove", function(e){
    if (!down) return;

    if (e.cancelable) e.preventDefault();
    e.stopPropagation();

    var dx = e.clientX - startX;
    var dy = e.clientY - startY;

    if (Math.abs(dx) > 4 || Math.abs(dy) > 4) {
      dragging = true;
      hideBubble();
    }

    if (dragging) {
      pos.left = startLeft + dx;
      pos.bottom = startBottom - dy;
      applyPos();
    }
  }, true);

  function finishPointer(e){
    if (!down) return;

    if (e && e.cancelable) e.preventDefault();
    if (e) e.stopPropagation();

    if (dragging) {
      savePos();
      applyBubblePos();
    } else {
      showBubble();
    }

    down = false;
    dragging = false;

    setTimeout(function(){
      unlockPage();
    }, 80);
  }

  document.addEventListener("pointerup", finishPointer, true);
  document.addEventListener("pointercancel", finishPointer, true);

  window.addEventListener("resize", function(){
    applyPos();
    savePos();
  });

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLive2d);
  } else {
    initLive2d();
  }
})();
</script>
