# DINGHONG environment variables template
# Copy this file to a server-only .env / systemd EnvironmentFile / shell profile.
# Do not commit real production values.

# Server
SERVER_PORT=8080

# Database
DB_URL=jdbc:mysql://127.0.0.1:3306/dinghong?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
DB_USER=dinghong
DB_PASSWORD=change-me

# Admin / JWT
# All controllers now read these via Spring @Value. Missing values will fail at startup.
ADMIN_USER=admin
ADMIN_PASS=change-me
JWT_SECRET=change-me-to-a-random-32-byte-minimum-secret
JWT_EXPIRATION_MS=86400000

# Live proxy
LIVE_PROXY_SECRET=change-me-random-proxy-secret

# The Odds API
# Default is false to avoid the odds post-processing path overriding different author opinions.
ODDS_API_ENABLED=false
ODDS_API_KEY=
ODDS_API_REGIONS=eu,uk,us
ODDS_API_MARKETS=h2h,spreads,totals
ODDS_API_ODDS_FORMAT=decimal
ODDS_API_FOOTBALL_SPORTS=soccer_epl,soccer_uefa_champs_league,soccer_spain_la_liga,soccer_italy_serie_a,soccer_germany_bundesliga
ODDS_API_BASKETBALL_SPORTS=basketball_nba,basketball_wnba

# WeChat official account
# Now read via Spring @Value(wechat.appid / wechat.secret) in WechatController.
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_VERIFY_TOKEN=change-me

# Upload
# Now read via Spring @Value(upload.dir / upload.public-base-url) in UploadController / LiveQrController.
UPLOAD_DIR=/data/dinghong/upload
UPLOAD_PUBLIC_BASE_URL=https://api.5q.lol/upload
LIVE_PLAY_BASE_URL=https://live.5q.lol/play.html?key=

# Optional search / AI providers
DEEPSEEK_API_KEY=
BAIDU_SEARCH_KEY=
BRAVE_API_KEY=
API_FOOTBALL_KEY=
